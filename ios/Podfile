# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# react-native-firebase: the Firebase iOS SDK (12.x) ships Swift pods (e.g.
# FirebaseAuth). Its umbrella header (`<Firebase/Firebase.h>`) unconditionally does
# `#import <FirebaseAuth/FirebaseAuth-Swift.h>`, which only resolves when Firebase
# is linked as frameworks. Static frameworks are the officially documented setup;
# they also resolve the static_framework=true requirement pulled in by
# react-native-bottom-tabs (Swift). See https://rnfirebase.io (iOS install notes).
$RNFirebaseAsStaticFramework = true

# Default to statically-linked frameworks (overridable via USE_FRAMEWORKS env).
linkage = ENV['USE_FRAMEWORKS'] || 'static'
Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
use_frameworks! :linkage => linkage.to_sym

target 'Safr' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Required for MapLibre
    $MLRN.post_install(installer)

    # Fix llama.rn under use_frameworks!: its podspec globs `ios/**/*.h`, which
    # accidentally pulls the internal headers of the vendored `rnllama.xcframework`
    # from BOTH slices (device + simulator) — same basenames. As a static lib this
    # is harmless, but as a framework each maps to llama_rn.framework/Headers/X.h →
    # "Multiple commands produce". Drop the xcframework's headers from llama-rn's
    # public Headers phase (they belong to the vendored framework, not llama_rn).
    installer.pods_project.targets.each do |target|
      next unless target.name == 'llama-rn'
      phase = target.headers_build_phase
      phase.files.dup.each do |bf|
        path = bf.file_ref.respond_to?(:real_path) ? bf.file_ref.real_path.to_s : bf.file_ref.path.to_s
        phase.remove_build_file(bf) if path.include?('.xcframework')
      end
    end

    # Fix: Remove -weak_framework FirebaseFirestoreInternal from linker flags
    # It's already linked as a static library (-l), the weak_framework flag causes "framework not found"
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |bc|
        ldflags = bc.build_settings['OTHER_LDFLAGS']
        if ldflags.is_a?(String)
          ldflags = ldflags.gsub(/-weak_framework\s+"?FirebaseFirestoreInternal"?/, '')
          bc.build_settings['OTHER_LDFLAGS'] = ldflags
        elsif ldflags.is_a?(Array)
          result = []
          skip_next = false
          ldflags.each_with_index do |flag, i|
            if skip_next
              skip_next = false
              next
            end
            if flag == '-weak_framework' && ldflags[i + 1] == 'FirebaseFirestoreInternal'
              skip_next = true
              next
            end
            result << flag
          end
          bc.build_settings['OTHER_LDFLAGS'] = result
        end
      end
    end

    # Also fix the xcconfig files directly
    Dir.glob(File.join(installer.sandbox.root, 'Target Support Files', '**', '*.xcconfig')).each do |xcconfig_path|
      xcconfig = File.read(xcconfig_path)
      if xcconfig.include?('-weak_framework "FirebaseFirestoreInternal"')
        xcconfig = xcconfig.gsub('-weak_framework "FirebaseFirestoreInternal"', '')
        File.write(xcconfig_path, xcconfig)
      end
    end
  end
end
