# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Safr' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # Firebase requires modular headers for Swift interop
  pod 'FirebaseCore', :modular_headers => true
  pod 'FirebaseCoreInternal', :modular_headers => true
  pod 'FirebaseFirestore', :modular_headers => true
  pod 'FirebaseFirestoreInternal', :modular_headers => true
  pod 'FirebaseCoreExtension', :modular_headers => true
  pod 'FirebaseSharedSwift', :modular_headers => true
  pod 'FirebaseAppCheckInterop', :modular_headers => true
  pod 'GoogleUtilities', :modular_headers => true
  pod 'nanopb', :modular_headers => true

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Required for MapLibre
    $MLRN.post_install(installer)

    # Fix: Remove -weak_framework FirebaseFirestoreInternal from linker flags
    # It's already linked as a static library (-l), the weak_framework flag causes "framework not found"
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |bc|
        ldflags = bc.build_settings['OTHER_LDFLAGS']
        if ldflags.is_a?(String)
          ldflags = ldflags.gsub(/-weak_framework\s+"?FirebaseFirestoreInternal"?/, '')
          bc.build_settings['OTHER_LDFLAGS'] = ldflags
        elsif ldflags.is_a?(Array)
          result = []
          skip_next = false
          ldflags.each_with_index do |flag, i|
            if skip_next
              skip_next = false
              next
            end
            if flag == '-weak_framework' && ldflags[i + 1] == 'FirebaseFirestoreInternal'
              skip_next = true
              next
            end
            result << flag
          end
          bc.build_settings['OTHER_LDFLAGS'] = result
        end
      end
    end

    # Also fix the xcconfig files directly
    Dir.glob(File.join(installer.sandbox.root, 'Target Support Files', '**', '*.xcconfig')).each do |xcconfig_path|
      xcconfig = File.read(xcconfig_path)
      if xcconfig.include?('-weak_framework "FirebaseFirestoreInternal"')
        xcconfig = xcconfig.gsub('-weak_framework "FirebaseFirestoreInternal"', '')
        File.write(xcconfig_path, xcconfig)
      end
    end
  end
end
